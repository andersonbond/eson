# Persona (IDENTITY.md, SOUL.md, Eson.md) — default: ./persona when cwd is eson/, else next to Cargo crate
# ESON_PERSONA_DIR=/absolute/path/to/persona

# Workspace root (absolute or relative to agent CWD)
ESON_WORKSPACE_ROOT=./workspace
ESON_WORKSPACE_ONLY_PATHS=true
ESON_ALLOW_ABSOLUTE_PATHS=false

# Agent tools: SQLite memory for store_memory / recall_memory (default: <workspace>/db/memory.db)
ESON_AGENT_MEMORY_DB=db/memory.db

# macOS/Unix: run_terminal tool (cwd = workspace). Disable with 0/false.
ESON_TERMINAL_ENABLED=1
ESON_TERMINAL_TIMEOUT_SEC=600
ESON_TERMINAL_MAX_OUTPUT_BYTES=500000
ESON_TERMINAL_ALLOW_SUDO=0

# Agent HTTP + Socket.IO
ESON_AGENT_HTTP_PORT=8787
ESON_SOCKETIO_PORT=8788

# Memory sidecar
ESON_MEMORY_PORT=8888
ESON_MEMORY_URL=http://127.0.0.1:8888

# Desktop Settings prefill: GET /session/provider-defaults returns models (and API keys when enabled).
# Set to 0 or false to hide keys from the UI prefill (keys still work from env on the agent).
ESON_EXPOSE_LLM_SECRETS_TO_UI=1

# Per-call HTTP timeout for every LLM request (covers connect + streaming body).
# Default 600 s (10 min) so slow local models (Ollama gemma4:e4b on CPU) can
# finish a single round even after a heavy tool result is appended to the
# prompt. Raise if your local model is slower; cloud APIs stay well under
# this. Per-session override: Settings → AI Provider → Advanced (no
# restart needed). Hard-capped at 3600 s.
# ESON_LLM_HTTP_TIMEOUT_SECS=600

# Ollama Default model matches local vision.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e4b
# OLLAMA_API_KEY=ollama
# OLLAMA_MAX_TOKENS=8192
# Use a model that supports tool calling via Ollama’s OpenAI-compatible /v1/chat/completions API.

# Claude (Anthropic) — used by eson-agent for /session/message
# Loaded from eson/.env then eson/.env.local (override). Restart agent after changes.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_MAX_TOKENS=8192
# Extended-thinking budget (tokens). 0 disables, default 1024 — emits an
# `llm_thinking` socket event per round, surfaced in the chat reasoning panel.
# ANTHROPIC_THINKING_BUDGET=1024

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MAX_TOKENS=8192
# Workspace tools (store_memory, run_terminal, …) use OpenAI Chat Completions `tools` / `tool_calls`.
# Custom OPENAI_BASE_URL must implement the same contract (e.g. Azure OpenAI, vLLM, LiteLLM proxy).

# Skills folder (default: ./skills from agent cwd, or repo skills/ next to Cargo)
# ESON_SKILLS_DIR=/absolute/path/to/skills

# Background loop: cron skills + inbox watcher.
ESON_BACKGROUND_LOOP_ENABLED=1
ESON_HEARTBEAT_SEC=60
ESON_INBOX_AUTO_PROCESS=1
ESON_INBOX_DEBOUNCE_MS=500
# Provider used for background turns. Settings panel can override per-install
# and persist to <workspace>/db/background_settings.json. Default: ollama.
# Falls back automatically to anthropic (then openai) if the chosen provider
# isn't configured at fire time.
# ESON_BACKGROUND_PROVIDER=ollama

# Vision routing for analyze_visual / pdf_to_table. Three providers:
#   ollama    — fully local via Ollama /api/generate (default; gemma4:e4b)
#   anthropic — Claude vision via /v1/messages (uses ANTHROPIC_API_KEY)
#   openai    — GPT-4o family via /v1/chat/completions (uses OPENAI_API_KEY)
# The user can also pick this live in Settings → Vision (no restart needed).
ESON_VISION_PROVIDER=ollama
ESON_VISION_MODEL=gemma4:e4b
ESON_VISION_OLLAMA_URL=http://127.0.0.1:11434
ESON_VISION_PDF_MAX_PAGES=50
ESON_VISION_ALLOW_CLOUD=0

# Concurrency caps
ESON_MAX_CONCURRENT_TOOLS=10000
ESON_MAX_TOOL_QUEUE_DEPTH=1000

# LLM tool-orchestration rounds per user message (default 1000, max 1000)
ESON_MAX_LLM_TOOL_ROUNDS=1000

# Local dev: allow Socket.IO from Tauri webview
ESON_SOCKETIO_CORS_ORIGINS=http://localhost:1420,http://127.0.0.1:1420,tauri://localhost

# Optional cloud fallback (off by default; wire in provider layer when enabled)
ESON_CLOUD_FALLBACK_ENABLED=false

# LiveKit server (required)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret