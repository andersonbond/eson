{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window — core only (minimal)",
  "windows": ["main"],
  "local": true,
  "remote": {
    "urls": [
      "http://127.0.0.1:1420",
      "http://127.0.0.1:1420/*",
      "http://localhost:1420",
      "http://localhost:1420/*",
      "ws://127.0.0.1:1420",
      "ws://127.0.0.1:1420/*",
      "ws://localhost:1420",
      "ws://localhost:1420/*"
    ]
  },
  "permissions": [
    "core:default",
    "core:event:default",
    "core:path:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/eson-agent", "sidecar": true },
        { "name": "binaries/eson-memory", "sidecar": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/eson-agent", "sidecar": true },
        { "name": "binaries/eson-memory", "sidecar": true }
      ]
    },
    "shell:allow-kill",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:*" },
        { "url": "http://localhost:*" }
      ]
    }
  ]
}
